# ==========================================
# ОСНОВНЫЕ НАСТРОЙКИ СИСТЕМЫ
# ==========================================

# Режим клиента:
# 'telegram' - только Telegram-бот (TELEGRAM_BOT_TOKEN обязателен)
# 'web'      - только REST API + WebSocket (бот не запускается, токен не нужен)
# 'all'      - и бот, и API одновременно (по умолчанию)
CLIENT_MODE=all

# Режим работы приложения:
# 'personal'     - читает почту одного владельца, уведомляет его через Telegram / WebSocket
# 'centralized'  - читает пересланные письма, ищет пользователя по email в БД
APP_MODE=personal

# Telegram ID владельца бота (personal + CLIENT_MODE=telegram или all).
# Узнать свой ID: написать @userinfobot в Telegram.
ADMIN_TG_ID=

# Email владельца (fallback для personal + CLIENT_MODE=web, когда нет ADMIN_TG_ID).
ADMIN_EMAIL=

# Строка подключения к базе данных.
# SQLite (локальная разработка): sqlite+aiosqlite:///app.db
# PostgreSQL: postgresql+asyncpg://user:pass@localhost/db_name
DATABASE_URL=sqlite+aiosqlite:///app.db


# ==========================================
# ПОЧТОВЫЙ СЕРВЕР (IMAP)
# ==========================================

# Адрес IMAP сервера.
# Яндекс: imap.yandex.ru
# Почта HSE (Office 365): outlook.office365.com
# Gmail: imap.gmail.com
# Mail.ru: imap.mail.ru
IMAP_SERVER=imap.gmail.com

# Ваш логин от почты (email целиком)
EMAIL_USER=your-email@gmail.com

# Пароль приложения (APP PASSWORD).
# ВНИМАНИЕ: Обычный пароль от входа на сайт НЕ ПОДОЙДЕТ.
# Нужно сгенерировать специальный "Пароль приложения" в настройках безопасности вашей почты.
# Gmail: https://myaccount.google.com/apppasswords
# Яндекс: https://id.yandex.ru/security/app-passwords
EMAIL_PASSWORD=xxxx xxxx xxxx xxxx


# ==========================================
# TELEGRAM БОТ
# ==========================================

# Токен бота, полученный у @BotFather в Telegram
TELEGRAM_BOT_TOKEN=

# Username бота без @ (нужен для Telegram Login Widget на фронтенде)
TELEGRAM_BOT_USERNAME=


# ==========================================
# НЕЙРОСЕТЬ / AI
# ==========================================

# API ключ от сервиса OpenRouter (https://openrouter.ai/)
OPENROUTER_API_KEY=

# Модель для анализа писем.
# Бесплатные: google/gemini-2.5-flash-preview-05-20 или meta-llama/llama-3-8b-instruct:free
# Платные: anthropic/claude-3-haiku или openai/gpt-4o-mini
LLM_MODEL=google/gemini-2.5-flash-preview-05-20


# ==========================================
# REST API / JWT
# ==========================================

# Порт REST API
API_PORT=8000

# Секрет для подписи JWT токенов. ОБЯЗАТЕЛЬНО смените в production!
# Сгенерировать: python -c "import secrets; print(secrets.token_urlsafe(32))"
JWT_SECRET_KEY=change-me-in-production

# Время жизни JWT токена в минутах (по умолчанию 1440 = 24 часа)
JWT_ACCESS_TOKEN_EXPIRE_MINUTES=1440

# Разрешённые CORS origins (через запятую).
# Для локальной разработки с фронтендом на Vite:
CORS_ORIGINS=http://localhost:5173,http://localhost:3000


# ==========================================
# SMTP (верификация email, сброс пароля)
# ==========================================

# SMTP сервер (по умолчанию smtp.gmail.com)
SMTP_SERVER=smtp.gmail.com
# SMTP порт (587 = STARTTLS, 465 = SSL)
SMTP_PORT=587
# Базовый URL приложения (для ссылок в письмах верификации)
# В production укажите реальный домен: https://your-domain.com
APP_BASE_URL=http://localhost:8000


# ==========================================
# WEBHOOK TELEGRAM (опционально)
# ==========================================

# Если задан — бот работает в webhook-режиме вместо polling.
# Для локальной разработки оставьте пустым.
WEBHOOK_URL=
WEBHOOK_PATH=/webhook/telegram


# ==========================================
# ЛОГИРОВАНИЕ
# ==========================================

LOG_DIR=logs
LOG_FILE=bot.log
# Максимальный размер лог-файла в байтах (5 MB)
LOG_MAX_BYTES=5242880
# Количество хранимых ротированных файлов
LOG_BACKUP_COUNT=3


# ==========================================
# FIREBASE PUSH-УВЕДОМЛЕНИЯ (опционально)
# ==========================================

# Путь к JSON-файлу сервисного аккаунта Firebase Admin SDK.
# Скачать: Firebase Console -> Project Settings -> Service Accounts -> Generate New Private Key
# Оставьте пустым, если push-уведомления не нужны.
FIREBASE_CREDENTIALS_PATH=
